                  bg="#555", fg="white", font=("Segoe UI", 11),
                  padx=20, pady=5, cursor="hand2").pack(side=tk.LEFT)

    def delete_game(self, item):
        """Удаление игры"""
        values = self.tree.item(item, "values")
        game_name = values[0] if values else "игру"
        if messagebox.askyesno("Подтверждение", f"Удалить игру '{game_name}'?"):
            conn = sqlite3.connect(DB_FILE)
            cursor = conn.cursor()
            cursor.execute("DELETE FROM games WHERE id = ?", (item,))
            conn.commit()
            conn.close()
            self.apply_filter()
            messagebox.showinfo("Удалено", f"Игра '{game_name}' удалена.")

    def clear_placeholder(self, entry, placeholder):
        if entry.get() == placeholder:
            entry.delete(0, tk.END)
            entry.config(foreground="black")

    def add_placeholder(self, entry, placeholder):
        if entry.get() == "":
            entry.insert(0, placeholder)
            entry.config(foreground="gray")
        else:
            entry.config(foreground="black")

    def add_game(self):
        """Добавление игры в БД с проверкой данных"""
        name = self.name_entry.get().strip()
        players = self.players_entry.get().strip()
        age = self.age_entry.get().strip()
        time_m = self.time_entry.get().strip()
        qty = self.quantity_spin.get().strip()

        # 1. Валидация через ваши методы (оставляем старую логику для гибкости)
        for val, func in [(name, self.validate_name), (players, self.validate_players),
                          (age, self.validate_age), (time_m, self.validate_time)]:
            is_valid, msg = func(val)
            if not is_valid:
                messagebox.showerror("Ошибка", msg)
                return

        # 2. Валидация количества (включая проверку на отрицательные)
        if not qty.isdigit() or int(qty) < 0:
            messagebox.showerror("Ошибка", "Количество должно быть целым положительным числом")
            return

        # 3. Выполнение SQL
        try:
            conn = sqlite3.connect(DB_FILE)
            cursor = conn.cursor()
            cursor.execute('''INSERT INTO games 
                (name, players, age, time_minutes, interaction, randomness, quantity) 
                VALUES (?,?,?,?,?,?,?)''',
                (name, players, age, time_m, self.interaction_combo.get(),
                 self.randomness_combo.get(), int(qty)))
            conn.commit()
            conn.close()
            self.load_games()
            messagebox.showinfo("Успех", "Игра добавлена!")
        except Exception as e:
            messagebox.showerror("Ошибка БД", str(e))

    def load_games(self):
        """Загружает все игры и применяет текущий фильтр"""
        self.apply_filter()


