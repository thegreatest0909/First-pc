        quantity_spin.insert(0, quantity)
        available_var_inner.set(int(quantity) > 0)

        # Функция для проверки количества при потере фокуса в диалоге
        def validate_quantity_focus_edit(event=None):
            value = quantity_spin.get().strip()
            if value == "":
                quantity_spin.delete(0, tk.END)
                quantity_spin.insert(0, "1" if available_var_inner.get() else "0")
                return

            if not value.isdigit():
                quantity_spin.delete(0, tk.END)
                quantity_spin.insert(0, "1" if available_var_inner.get() else "0")
                messagebox.showwarning("Некорректное значение", "Количество должно быть целым положительным числом.")
                return

            try:
                num = int(value)
                if num < 0:
                    quantity_spin.delete(0, tk.END)
                    quantity_spin.insert(0, "0")
                    messagebox.showwarning("Некорректное значение",
                                           "Количество не может быть отрицательным. Установлено 0.")
                elif num > 999:
                    quantity_spin.delete(0, tk.END)
                    quantity_spin.insert(0, "999")
                    messagebox.showwarning("Некорректное значение", "Количество не может превышать 999.")
                elif available_var_inner.get() and num == 0:
                    quantity_spin.delete(0, tk.END)
                    quantity_spin.insert(0, "1")
                    messagebox.showwarning("Некорректное значение",
                                           "Если игра в наличии, количество должно быть не менее 1.")
                elif not available_var_inner.get() and num != 0:
                    quantity_spin.delete(0, tk.END)
                    quantity_spin.insert(0, "0")
                    messagebox.showwarning("Некорректное значение", "Если игра не в наличии, количество должно быть 0.")
            except ValueError:
                quantity_spin.delete(0, tk.END)
                quantity_spin.insert(0, "1" if available_var_inner.get() else "0")

        quantity_spin.bind("<FocusOut>", validate_quantity_focus_edit)

        # Функция для обновления количества при изменении чекбокса
        def on_available_change_edit():
            if not available_var_inner.get():
                quantity_spin.delete(0, tk.END)
                quantity_spin.insert(0, "0")
            else:
                current_val = quantity_spin.get()
                if current_val == "0" or current_val == "":
                    quantity_spin.delete(0, tk.END)
                    quantity_spin.insert(0, "1")

        available_check.config(command=on_available_change_edit)

        def save_changes():
            # Валидация всех полей
            new_name = name_entry.get().strip()
            valid, error = self.validate_name(new_name)
            if not valid:
                self.show_field_error("Название", error)
                name_entry.focus()
                return

            new_players = players_entry.get().strip()
            valid, error = self.validate_players(new_players)
            if not valid:
                self.show_field_error("Игроки", error)
                players_entry.focus()
                return

            new_age = age_entry.get().strip()
            valid, error = self.validate_age(new_age)
            if not valid:
                self.show_field_error("Возраст", error)
                age_entry.focus()
                return

            new_time = time_entry.get().strip()
            valid, error = self.validate_time(new_time)
            if not valid:
                self.show_field_error("Время партии", error)
                time_entry.focus()
                return

            try:
                quantity_text = quantity_spin.get().strip()
                if quantity_text == "":
                    self.show_field_error("Количество", "Поле 'Количество' не может быть пустым")
                    quantity_spin.focus()
                    return

                if not quantity_text.isdigit() or quantity_text.startswith('-'):
                    self.show_field_error("Количество",
                                          "Количество должно быть целым неотрицательным числом (без минуса и дробных)")
                    quantity_spin.focus()
                    return

                new_quantity = int(quantity_text)

                valid, error = self.validate_quantity(new_quantity, available_var_inner.get())
                if not valid:
                    self.show_field_error("Количество", error)
                    quantity_spin.focus()
                    return

            except ValueError:
                self.show_field_error("Количество", "Количество должно быть целым положительным числом")
                quantity_spin.focus()
                return

            conn = sqlite3.connect(DB_FILE)
            cursor = conn.cursor()
            cursor.execute('''
                UPDATE games 
                SET name=?, players=?, age=?, time_minutes=?, interaction=?, randomness=?, quantity=?
                WHERE id=?
            ''', (new_name, new_players, new_age, new_time,
                  interaction_combo.get(), randomness_combo.get(), new_quantity, item))
            conn.commit()
            conn.close()
            dialog.destroy()
            self.apply_filter()
            messagebox.showinfo("Успех", f"Игра '{new_name}' обновлена!")

        btn_frame = tk.Frame(dialog, bg=CARD_BG)
        btn_frame.pack(pady=20)
