    def validate_all_fields(self, name, players, age, time_m, qty):
        """Проверяет данные и возвращает (True, "") или (False, "Сообщение об ошибке")"""
        if not name or name.strip() == "": return False, "Название не может быть пустым"

        # Регулярки для проверки: только цифры, дефис или плюс, никакого минуса в начале
        if not re.match(r'^\d+[\d\-]*$', players.strip()):
            return False, "Поле 'Игроки' должно содержать только положительные числа или формат 2-4"
        if not re.match(r'^\d+\+?$', age.strip()):
            return False, "Поле 'Возраст' должно быть числом (например, 12+)"
        if not re.match(r'^\d+[\d\-]*$', time_m.strip()):
            return False, "Поле 'Время' должно быть числом или диапазоном (например, 30-60)"
        if not qty.isdigit() or int(qty) < 0:
            return False, "Количество должно быть положительным числом"

        return True, ""

    def validate_all_fields(self):
        """Проверяет корректность всех полей ввода"""
        # Проверка игроков (только цифры и дефис, не может начинаться с минуса)
        players = self.players_entry.get().strip()
        if not re.match(r'^\d+[\d\-]*$', players):
            return False, "Поле 'Игроки' должно быть числом или диапазоном (например, 2-4)"

        # Проверка возраста (цифры и возможный плюс, без минусов)
        age = self.age_entry.get().strip()
        if not re.match(r'^\d+\+?$', age):
            return False, "Поле 'Возраст' должно быть числом (например, 12+)"

        # Проверка времени (только цифры и дефис)
        time = self.time_entry.get().strip()
        if not re.match(r'^\d+[\d\-]*$', time):
            return False, "Поле 'Время' должно быть числом или диапазоном (например, 30-60)"

        return True, ""

    def is_valid_input(self, value, field_type):
        """Проверка: не пусто, без минусов, только цифры/диапазоны."""
        val = value.strip()
        if not val or val == "" or val in ["Название игры...", "2–4", "12+", "30–60"]:
            return False
        if field_type == "int":  # Для количества
            return val.isdigit() and int(val) >= 0
        if field_type == "range":  # Для игроков/времени (цифры + дефис)
            return bool(re.match(r'^\d+[\d\-]*$', val))
        return True

