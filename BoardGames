    def validate_name(self, name):
        if not name or name.strip() == "" or name.strip() == "Название игры...":
            return False, "Название игры не может быть пустым"
        return True, ""

    def validate_players(self, players):
        if not re.match(r'^\d+[\d\-]*$', players.strip()):
            return False, "Поле 'Игроки' должно быть числом или диапазоном (напр. 2-4)"
        return True, ""

    def validate_age(self, age):
        if not re.match(r'^\d+\+?$', age.strip()):
            return False, "Поле 'Возраст' должно быть числом (напр. 12+)"
        return True, ""

    def validate_time(self, time_str):
        if not re.match(r'^\d+[\d\-]*$', time_str.strip()):
            return False, "Поле 'Время' должно быть числом или диапазоном (напр. 30-60)"
        return True, ""

    def validate_quantity(self, quantity, is_available):
        if quantity < 0:
            return False, "Количество не может быть отрицательным"
        if quantity > 999:
            return False, "Количество не может превышать 999"
        if is_available:
            if quantity < 1:
                return False, "Если игра в наличии, количество должно быть не менее 1"
        else:
            if quantity != 0:
                return False, "Если игра не в наличии, количество должно быть 0"
        return True, ""

