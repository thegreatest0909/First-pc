        available_check.config(command=on_available_change_edit)

        def save_changes():
            new_name = name_entry.get().strip()
            valid, error = self.validate_name(new_name)
            if not valid:
                self.show_field_error("Название", error)
                name_entry.focus()
                return

            new_players = players_entry.get().strip()
            valid, error = self.validate_players(new_players)
            if not valid:
                self.show_field_error("Игроки", error)
                players_entry.focus()
                return

            new_age = age_entry.get().strip()
            valid, error = self.validate_age(new_age)
            if not valid:
                self.show_field_error("Возраст", error)
                age_entry.focus()
                return

            new_time = time_entry.get().strip()
            valid, error = self.validate_time(new_time)
            if not valid:
                self.show_field_error("Время партии", error)
                time_entry.focus()
                return

            try:
                price_text = price_edit_entry.get().strip()
                price_text = re.sub(r'[^\d.]', '', price_text)
                new_price = float(price_text) if price_text else 0
                if new_price < 0:
                    new_price = 0
            except ValueError:
                self.show_field_error("Цена", "Цена должна быть числом")
                price_edit_entry.focus()
                return

            try:
                quantity_text = quantity_spin.get().strip()
                if quantity_text == "":
                    self.show_field_error("Количество", "Поле 'Количество' не может быть пустым")
                    quantity_spin.focus()
                    return

                if not quantity_text.isdigit() or quantity_text.startswith('-'):
                    self.show_field_error("Количество", "Количество должно быть целым неотрицательным числом")
                    quantity_spin.focus()
                    return

                new_quantity = int(quantity_text)
                valid, error = self.validate_quantity(new_quantity, available_var_inner.get())
                if not valid:
                    self.show_field_error("Количество", error)
                    quantity_spin.focus()
                    return

            except ValueError:
                self.show_field_error("Количество", "Количество должно быть целым положительным числом")
                quantity_spin.focus()
                return

            conn = sqlite3.connect(DB_FILE)
            cursor = conn.cursor()
            cursor.execute('''
                UPDATE games 
                SET name=?, players=?, age=?, time_minutes=?, interaction=?, randomness=?, complexity=?, quantity=?, price=?
                WHERE id=?
            ''', (new_name, new_players, new_age, new_time,
                  interaction_combo.get(), randomness_combo.get(), complexity_combo.get(), new_quantity, new_price,
                  item))
            conn.commit()
            conn.close()
            dialog.destroy()
            self.load_games()
            messagebox.showinfo("Успех", f"Игра '{new_name}' обновлена!")

        btn_frame = tk.Frame(dialog, bg=CARD_BG)
        btn_frame.pack(pady=20)
        tk.Button(btn_frame, text="Сохранить", command=save_changes,
                  bg=ACCENT, fg="white", font=("Segoe UI", 11, "bold"),
                  padx=20, pady=5, cursor="hand2").pack(side=tk.LEFT, padx=10)
        tk.Button(btn_frame, text="Отмена", command=dialog.destroy,
                  bg="#555", fg="white", font=("Segoe UI", 11),
                  padx=20, pady=5, cursor="hand2").pack(side=tk.LEFT)

    def delete_game(self, item):
        values = self.tree.item(item, "values")
        game_name = values[0] if values else "игру"
        if messagebox.askyesno("Подтверждение", f"Удалить игру '{game_name}'?"):
            conn = sqlite3.connect(DB_FILE)
            cursor = conn.cursor()
            cursor.execute("DELETE FROM games WHERE id = ?", (item,))
            conn.commit()
            conn.close()
            self.load_games()
            messagebox.showinfo("Удалено", f"Игра '{game_name}' удалена.")

    def clear_placeholder(self, entry, placeholder):
        if entry.get() == placeholder:
            entry.delete(0, tk.END)
            entry.config(foreground="black")

    def add_placeholder(self, entry, placeholder):
        if entry.get() == "":
            entry.insert(0, placeholder)
            entry.config(foreground="gray")
        else:
            entry.config(foreground="black")

    def add_game(self):
        name = self.name_entry.get().strip()
        players = self.players_entry.get().strip()
        age = self.age_entry.get().strip()
        time_m = self.time_entry.get().strip()
        qty = self.quantity_spin.get().strip()
        price_text = self.price_entry.get().strip()
        complexity = self.complexity_combo.get()

        for val, func in [(name, self.validate_name), (players, self.validate_players),
                          (age, self.validate_age), (time_m, self.validate_time)]:
            is_valid, msg = func(val)
            if not is_valid:
                messagebox.showerror("Ошибка", msg)
                return

        if not qty.isdigit() or int(qty) < 0:
            messagebox.showerror("Ошибка", "Количество должно быть целым положительным числом")
            return

        try:
            price_text = re.sub(r'[^\d.]', '', price_text)
            price = float(price_text) if price_text else 0
            if price < 0:
                price = 0
        except ValueError:
            messagebox.showerror("Ошибка", "Цена должна быть числом")
            self.price_entry.focus()
            return

        try:
            conn = sqlite3.connect(DB_FILE)
            cursor = conn.cursor()
            cursor.execute('''INSERT INTO games 
                (name, players, age, time_minutes, interaction, randomness, complexity, quantity, price) 
                VALUES (?,?,?,?,?,?,?,?,?)''',
                           (name, players, age, time_m, self.interaction_combo.get(),
                            self.randomness_combo.get(), complexity, int(qty), price))
            conn.commit()
            conn.close()
            self.load_games()

            self.name_entry.delete(0, tk.END)
            self.name_entry.insert(0, "Название игры...")
            self.players_entry.delete(0, tk.END)
            self.players_entry.insert(0, "2–4")
            self.age_entry.delete(0, tk.END)
            self.age_entry.insert(0, "12+")
            self.time_entry.delete(0, tk.END)
            self.time_entry.insert(0, "30–60")
            self.quantity_spin.delete(0, tk.END)
            self.quantity_spin.insert(0, "1")
            self.price_entry.delete(0, tk.END)
            self.price_entry.insert(0, "0.00")
            self.interaction_combo.set("Кооперативная")
            self.randomness_combo.set("Низкий")
            self.complexity_combo.set("Средняя")
            self.available_var.set(True)

            messagebox.showinfo("Успех", "Игра добавлена!")
        except Exception as e:
            messagebox.showerror("Ошибка БД", str(e))

    def load_games(self):
        self.apply_filter()


