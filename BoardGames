APP_NAME = "BoardGames"


def get_app_data_path():
    """
    Возвращает путь к папке приложения в AppData
    Создаёт папку, если её нет
    """
    if getattr(sys, 'frozen', False):
        # Запущено как .exe
        app_data = os.environ.get('APPDATA', os.path.expanduser('~\\AppData\\Roaming'))
    else:
        # Запущено как .py (разработка)
        app_data = os.environ.get('APPDATA', os.path.expanduser('~\\AppData\\Roaming'))

    # Путь к папке приложения
    app_folder = os.path.join(app_data, APP_NAME)

    # Создаём папку, если её нет
    if not os.path.exists(app_folder):
        os.makedirs(app_folder)

    return app_folder


# Получаем пути к системным файлам
APP_DATA_PATH = get_app_data_path()
SETTINGS_FILE = os.path.join(APP_DATA_PATH, "app_settings.json")
DB_FILE = os.path.join(APP_DATA_PATH, "board_games.db")


def load_settings():
    """Загружает сохранённые настройки"""
    default_settings = {
        "last_export_path": str(Path.home() / "Desktop"),
        "last_import_path": str(Path.home() / "Desktop"),
        "window_geometry": "1300x750"
    }
    if os.path.exists(SETTINGS_FILE):
        try:
            with open(SETTINGS_FILE, 'r', encoding='utf-8') as f:
                saved = json.load(f)
                default_settings.update(saved)
        except:
            pass
    return default_settings


def save_settings(settings):
    """Сохраняет настройки"""
    try:
        with open(SETTINGS_FILE, 'w', encoding='utf-8') as f:
            json.dump(settings, f, ensure_ascii=False, indent=2)
    except:
        pass


# Инициализация базы данных
def init_db():
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS games (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            players TEXT,
            age TEXT,
            time_minutes TEXT,
            interaction TEXT,
            randomness TEXT,
            quantity INTEGER DEFAULT 1
        )
    ''')
    conn.commit()
    conn.close()


