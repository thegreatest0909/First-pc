        tk.Label(dialog, text="Тип взаимодействия", font=("Segoe UI", 10, "bold"),
                 bg=CARD_BG, fg=FG_LIGHT).pack(anchor="w", padx=20, pady=(5, 5))
        interaction_combo = ttk.Combobox(dialog, values=["Кооперативная", "Соревновательная", "Командная", "Соло"],
                                         font=("Segoe UI", 11), state="readonly")
        interaction_combo.pack(padx=20, pady=(0, 10), fill=tk.X)
        interaction_combo.set(interaction)

        tk.Label(dialog, text="Случайность", font=("Segoe UI", 10, "bold"),
                 bg=CARD_BG, fg=FG_LIGHT).pack(anchor="w", padx=20, pady=(5, 5))
        randomness_combo = ttk.Combobox(dialog, values=["Низкий", "Средний", "Высокий"],
                                        font=("Segoe UI", 11), state="readonly")
        randomness_combo.pack(padx=20, pady=(0, 10), fill=tk.X)
        randomness_combo.set(randomness)

        tk.Label(dialog, text="Количество", font=("Segoe UI", 10, "bold"),
                 bg=CARD_BG, fg=FG_LIGHT).pack(anchor="w", padx=20, pady=(5, 5))
        quantity_spin = ttk.Spinbox(dialog, from_=0, to=99, width=10, font=("Segoe UI", 11))
        quantity_spin.pack(padx=20, pady=(0, 20), anchor="w")
        quantity_spin.delete(0, tk.END)
        quantity_spin.insert(0, quantity)

        def save_changes():
            new_name = name_entry.get().strip()
            if not new_name:
                messagebox.showwarning("Ошибка", "Название не может быть пустым")
                return
            try:
                new_quantity = int(quantity_spin.get())
            except ValueError:
                new_quantity = 0

            conn = sqlite3.connect(DB_FILE)
            cursor = conn.cursor()
            cursor.execute('''
                UPDATE games 
                SET name=?, players=?, age=?, time_minutes=?, interaction=?, randomness=?, quantity=?
                WHERE id=?
            ''', (new_name, players_entry.get(), age_entry.get(), time_entry.get(),
                  interaction_combo.get(), randomness_combo.get(), new_quantity, item))
            conn.commit()
            conn.close()
            dialog.destroy()
            self.apply_filter()
            messagebox.showinfo("Успех", f"Игра '{new_name}' обновлена!")

        btn_frame = tk.Frame(dialog, bg=CARD_BG)
        btn_frame.pack(pady=20)
        tk.Button(btn_frame, text="Сохранить", command=save_changes,
                  bg=ACCENT, fg="white", font=("Segoe UI", 11, "bold"),
                  padx=20, pady=5, cursor="hand2").pack(side=tk.LEFT, padx=10)
        tk.Button(btn_frame, text="Отмена", command=dialog.destroy,
                  bg="#555", fg="white", font=("Segoe UI", 11),
                  padx=20, pady=5, cursor="hand2").pack(side=tk.LEFT)

    def delete_game(self, item):
        """Удаление игры"""
        values = self.tree.item(item, "values")
        game_name = values[0] if values else "игру"
        if messagebox.askyesno("Подтверждение", f"Удалить игру '{game_name}'?"):
            conn = sqlite3.connect(DB_FILE)
            cursor = conn.cursor()
            cursor.execute("DELETE FROM games WHERE id = ?", (item,))
            conn.commit()
            conn.close()
            self.apply_filter()
            messagebox.showinfo("Удалено", f"Игра '{game_name}' удалена.")

    def clear_placeholder(self, entry, placeholder):
        if entry.get() == placeholder:
            entry.delete(0, tk.END)
            entry.config(foreground="black")

    def add_placeholder(self, entry, placeholder):
        if entry.get() == "":
            entry.insert(0, placeholder)
            entry.config(foreground="gray")
        else:
            entry.config(foreground="black")

    def add_game(self):
        name = self.name_entry.get().strip()
        if not name or name == "Название игры...":
            messagebox.showwarning("Ошибка", "Введите название игры")
            return

        players = self.players_entry.get().strip()
        age = self.age_entry.get().strip()
        time_str = self.time_entry.get().strip()
        interaction = self.interaction_combo.get()
        randomness = self.randomness_combo.get()
        quantity = int(self.quantity_spin.get()) if self.available_var.get() else 0

        conn = sqlite3.connect(DB_FILE)
        cursor = conn.cursor()
        cursor.execute('''
            INSERT INTO games (name, players, age, time_minutes, interaction, randomness, quantity)
            VALUES (?, ?, ?, ?, ?, ?, ?)
        ''', (name, players, age, time_str, interaction, randomness, quantity))
        conn.commit()
        conn.close()

        # Очистка формы
        self.name_entry.delete(0, tk.END)
        self.add_placeholder(self.name_entry, "Название игры...")
        self.players_entry.delete(0, tk.END)
        self.add_placeholder(self.players_entry, "2–4")
        self.age_entry.delete(0, tk.END)
        self.add_placeholder(self.age_entry, "12+")
        self.time_entry.delete(0, tk.END)
        self.add_placeholder(self.time_entry, "30–60")
        self.interaction_combo.set("Кооперативная")
        self.randomness_combo.set("Низкий")
        self.quantity_spin.delete(0, tk.END)
        self.quantity_spin.insert(0, "1")
        self.available_var.set(True)

        self.apply_filter()
        messagebox.showinfo("Успех", f"Игра '{name}' добавлена!")

    def load_games(self):
        """Загружает все игры и применяет текущий фильтр"""
        self.apply_filter()


