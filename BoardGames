    def sort_column(self, col, reverse):
        """Универсальная сортировка для всех колонок"""
        # 1. Получаем данные
        l = [(self.tree.set(k, col), k) for k in self.tree.get_children('')]

        # 2. Словари весов для категорий
        randomness_weights = {"Низкий": 1, "Средний": 2, "Высокий": 3}
        complexity_weights = {"Низкая": 1, "Средняя": 2, "Высокая": 3}

        def get_sort_key(item):
            val = item[0]

            # Сортировка для Случайности
            if col == 'randomness':
                return randomness_weights.get(val, 0)

            # Сортировка для Сложности
            if col == 'complexity':
                return complexity_weights.get(val, 0)

            # Сортировка для Возраста (извлекаем число из '12+')
            if col == 'age':
                nums = re.findall(r'\d+', val)
                return int(nums[0]) if nums else 0

            # Сортировка для чисел (Цена, Время, Кол-во)
            try:
                # Убираем пробелы, меняем запятую на точку
                clean_val = val.replace(',', '.').replace(' ', '')
                return float(clean_val)
            except ValueError:
                pass

            # Обычная сортировка (Название)
            return val.lower()

        # 3. Сортируем
        l.sort(key=get_sort_key, reverse=reverse)

        # 4. Переставляем строки
        for index, (val, k) in enumerate(l):
            self.tree.move(k, '', index)

        # 5. Меняем направление сортировки для следующего клика
        self.tree.heading(col, command=lambda: self.sort_column(col, not reverse))

        # Обновляем кнопки, если они привязаны к строкам
        if hasattr(self, 'refresh_buttons'):
            self.after(50, self.refresh_buttons)

