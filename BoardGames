    def apply_filter(self):
        name_filter = self.filter_name.get().strip().lower()
        players_filter = self.filter_players.get().strip().lower()
        age_filter = self.filter_age.get().strip().lower()
        time_filter = self.filter_time.get().strip().lower()
        interaction_filter = self.filter_interaction.get()
        randomness_filter = self.filter_randomness.get()
        complexity_filter = self.filter_complexity.get()

        try:
            qty_min = int(self.filter_qty_min.get()) if self.filter_qty_min.get().strip() else None
            if qty_min is not None and qty_min < 0:
                qty_min = 0
        except ValueError:
            qty_min = None
        try:
            qty_max = int(self.filter_qty_max.get()) if self.filter_qty_max.get().strip() else None
            if qty_max is not None and qty_max < 0:
                qty_max = 0
        except ValueError:
            qty_max = None

        try:
            price_min = float(self.filter_price_min.get()) if self.filter_price_min.get().strip() else None
            if price_min is not None and price_min < 0:
                price_min = 0
        except ValueError:
            price_min = None
        try:
            price_max = float(self.filter_price_max.get()) if self.filter_price_max.get().strip() else None
            if price_max is not None and price_max < 0:
                price_max = 0
        except ValueError:
            price_max = None

        conn = sqlite3.connect(DB_FILE)
        cursor = conn.cursor()
        cursor.execute(
            "SELECT id, name, players, age, time_minutes, interaction, randomness, complexity, quantity, price FROM games ORDER BY name")
        all_games = cursor.fetchall()
        conn.close()

        filtered = []
        for game in all_games:
            game_id, name, players, age, time_str, interaction, randomness, complexity, quantity, price = game

            if name_filter and name_filter not in name.lower():
                continue
            if players_filter and players_filter not in players.lower():
                continue
            if age_filter and age_filter not in age.lower():
                continue
            if time_filter and time_filter not in time_str.lower():
                continue
            if interaction_filter and interaction != interaction_filter:
                continue
            if randomness_filter and randomness != randomness_filter:
                continue
            if complexity_filter and complexity != complexity_filter:
                continue
            if qty_min is not None and quantity < qty_min:
                continue
            if qty_max is not None and quantity > qty_max:
                continue
            if price_min is not None and price < price_min:
                continue
            if price_max is not None and price > price_max:
                continue

            filtered.append(game)

        self.current_filtered_ids = [g[0] for g in filtered]

        for row in self.tree.get_children():
            self.tree.delete(row)

        if filtered:
            self.empty_label.place_forget()
            for game in filtered:
                game_id, name, players, age, time_str, interaction, randomness, complexity, quantity, price = game
                formatted_price = f"{price:.2f} ₽" if price else "0.00 ₽"
                self.tree.insert("", tk.END, iid=game_id,
                                 values=(name, players, age, time_str, interaction, randomness, complexity,
                                         quantity, formatted_price, ""))
        else:
            self.empty_label.config(text="Нет игр, соответствующих фильтру\nИзмените условия фильтрации")
            self.empty_label.place(relx=0.5, rely=0.5, anchor="center")

        # Обновляем кнопки после загрузки данных
        self.after(200, self.refresh_buttons)

