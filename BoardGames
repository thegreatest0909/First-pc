    def on_available_change(self):
        """Обработчик изменения состояния чекбокса 'В наличии'"""
        if not self.available_var.get():
            self.quantity_spin.delete(0, tk.END)
            self.quantity_spin.insert(0, "0")
        else:
            current_val = self.quantity_spin.get()
            if current_val == "0" or current_val == "":
                self.quantity_spin.delete(0, tk.END)
                self.quantity_spin.insert(0, "1")

    def validate_quantity_focus(self, event=None):
        """Проверяет значение в поле количества при потере фокуса"""
        value = self.quantity_spin.get().strip()

        # Если поле пустое
        if value == "":
            self.quantity_spin.delete(0, tk.END)
            self.quantity_spin.insert(0, "1" if self.available_var.get() else "0")
            return

        # Проверяем, что значение состоит только из цифр
        if not value.isdigit():
            self.quantity_spin.delete(0, tk.END)
            self.quantity_spin.insert(0, "1" if self.available_var.get() else "0")
            messagebox.showwarning("Ошибка ввода",
                                   "Количество должно быть целым неотрицательным числом (0-999).")
            return

        try:
            num = int(value)
            # Проверяем диапазон
            if num < 0:
                self.quantity_spin.delete(0, tk.END)
                self.quantity_spin.insert(0, "0")
                messagebox.showwarning("Некорректное значение",
                                       "Количество не может быть отрицательным. Установлено значение 0.")
            elif num > 999:
                self.quantity_spin.delete(0, tk.END)
                self.quantity_spin.insert(0, "999")
                messagebox.showwarning("Некорректное значение",
                                       "Количество не может превышать 999. Установлено максимальное значение.")
            else:
                # Если игра в наличии, проверяем что количество не 0
                if self.available_var.get() and num == 0:
                    self.quantity_spin.delete(0, tk.END)
                    self.quantity_spin.insert(0, "1")
                    messagebox.showwarning("Некорректное значение",
                                           "Если игра в наличии, количество должно быть не менее 1. Установлено значение 1.")
                # Если игра не в наличии, проверяем что количество равно 0
                elif not self.available_var.get() and num != 0:
                    self.quantity_spin.delete(0, tk.END)
                    self.quantity_spin.insert(0, "0")
                    messagebox.showwarning("Некорректное значение",
                                           "Если игра не в наличии, количество должно быть 0. Установлено значение 0.")
        except ValueError:
            self.quantity_spin.delete(0, tk.END)
            self.quantity_spin.insert(0, "1" if self.available_var.get() else "0")
            messagebox.showwarning("Некорректное значение",
                                   "Введите целое положительное число. Установлено значение по умолчанию.")

    def on_window_resize(self, event=None):
