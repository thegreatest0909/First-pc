    def apply_filter(self):
        """Применяет фильтр к таблице"""
        # Собираем значения фильтров
        name_filter = self.filter_name.get().strip().lower()
        players_filter = self.filter_players.get().strip().lower()
        age_filter = self.filter_age.get().strip().lower()
        time_filter = self.filter_time.get().strip().lower()
        interaction_filter = self.filter_interaction.get()
        randomness_filter = self.filter_randomness.get()

        try:
            qty_min = int(self.filter_qty_min.get()) if self.filter_qty_min.get().strip() else None
        except ValueError:
            qty_min = None
        try:
            qty_max = int(self.filter_qty_max.get()) if self.filter_qty_max.get().strip() else None
        except ValueError:
            qty_max = None

        # Получаем все игры из БД
        conn = sqlite3.connect(DB_FILE)
        cursor = conn.cursor()
        cursor.execute(
            "SELECT id, name, players, age, time_minutes, interaction, randomness, quantity FROM games ORDER BY name")
        all_games = cursor.fetchall()
        conn.close()

        # Фильтруем
        filtered = []
        for game in all_games:
            game_id, name, players, age, time_str, interaction, randomness, quantity = game

            # Фильтр по названию
            if name_filter and name_filter not in name.lower():
                continue

            # Фильтр по игрокам
            if players_filter and players_filter not in players.lower():
                continue

            # Фильтр по возрасту
            if age_filter and age_filter not in age.lower():
                continue

            # Фильтр по времени
            if time_filter and time_filter not in time_str.lower():
                continue

            # Фильтр по взаимодействию
            if interaction_filter and interaction != interaction_filter:
                continue

            # Фильтр по случайности
            if randomness_filter and randomness != randomness_filter:
                continue

            # Фильтр по количеству
            if qty_min is not None and quantity < qty_min:
                continue
            if qty_max is not None and quantity > qty_max:
                continue

            filtered.append(game)

        self.current_filtered_ids = [g[0] for g in filtered]

        # Обновляем таблицу
        for row in self.tree.get_children():
            self.tree.delete(row)

        if filtered:
            self.empty_label.place_forget()
            for game in filtered:
                game_id, name, players, age, time_str, interaction, randomness, quantity = game
                self.tree.insert("", tk.END, iid=game_id,
                                 values=(name, players, age, time_str, interaction, randomness, quantity, ""))
        else:
            # Показываем сообщение о пустом результате фильтрации
            self.empty_label.config(text="Нет игр, соответствующих фильтру\nИзмените условия фильтрации")
            self.empty_label.place(relx=0.5, rely=0.5, anchor="center")

        # Обновляем кнопки
        self.after(100, self.refresh_buttons)

    def reset_filter(self):
        """Сбрасывает все фильтры"""
        self.filter_name.delete(0, tk.END)
        self.filter_players.delete(0, tk.END)
        self.filter_age.delete(0, tk.END)
        self.filter_time.delete(0, tk.END)
        self.filter_interaction.set("")
        self.filter_randomness.set("")
        self.filter_qty_min.delete(0, tk.END)
        self.filter_qty_max.delete(0, tk.END)
        self.apply_filter()
        self.empty_label.config(text="База данных пуста\nИспользуйте форму слева для добавления первой игры")

    def on_scroll(self, *args):
        """Обработка прокрутки для синхронизации кнопок"""
        if args[0] == 'moveto':
            self.tree.yview(*args)
        else:
            self.tree.yview_scroll(args[1], args[0])
        self.refresh_buttons()

    def refresh_buttons(self, event=None):
        """Обновляет позиции кнопок-смайликов для всех видимых строк"""
        # Удаляем старые кнопки
        for btn_dict in self.action_buttons.values():
            for btn in btn_dict.values():
                if isinstance(btn, (tk.Button, tk.Frame)):
                    try:
                        btn.destroy()
                    except:
                        pass
        self.action_buttons.clear()

        # Для каждого элемента в tree создаём кнопки, если строка видима
        for item in self.tree.get_children():
            bbox = self.tree.bbox(item)
            if bbox:
                col_bbox = self.tree.bbox(item, column="#8")
                if col_bbox:
                    x, y, width, height = col_bbox
                    btn_frame = tk.Frame(self.tree, bg=CARD_BG)
                    btn_frame.place(x=x + 5, y=y + 2, width=width - 10, height=height - 4)

                    edit_btn = tk.Button(btn_frame, text="✏️", font=("Segoe UI", 10),
                                         bg=CARD_BG, fg=FG_LIGHT, bd=1, relief=tk.SOLID,
                                         highlightbackground=BUTTON_BORDER, highlightcolor=BUTTON_BORDER,
                                         highlightthickness=1, cursor="hand2",
                                         command=lambda i=item: self.edit_game(i))
                    edit_btn.pack(side=tk.LEFT, padx=2, expand=True, fill=tk.BOTH)

                    del_btn = tk.Button(btn_frame, text="🗑️", font=("Segoe UI", 10),
                                        bg=CARD_BG, fg=FG_LIGHT, bd=1, relief=tk.SOLID,
                                        highlightbackground=BUTTON_BORDER, highlightcolor=BUTTON_BORDER,
                                        highlightthickness=1, cursor="hand2",
                                        command=lambda i=item: self.delete_game(i))
                    del_btn.pack(side=tk.LEFT, padx=2, expand=True, fill=tk.BOTH)

                    self.action_buttons[item] = {"frame": btn_frame, "edit": edit_btn, "delete": del_btn}

    def export_to_excel(self):
        """Экспорт отфильтрованных игр в Excel файл с выбором пути"""
        # Собираем данные из отображаемых строк
        games_data = []
        for item in self.tree.get_children():
            values = self.tree.item(item, "values")
            if values and len(values) >= 7:
                games_data.append({
                    'Название': values[0],
                    'Игроки': values[1],
                    'Возраст': values[2],
                    'Время (мин)': values[3],
                    'Взаимодействие': values[4],
                    'Случайность': values[5],
                    'Количество': values[6]
                })

        if not games_data:
            messagebox.showwarning("Экспорт", "Нет данных для экспорта")
            return

        # Предлагаем выбрать путь для сохранения
        initial_dir = self.settings.get("last_export_path", str(Path.home() / "Desktop"))
        initial_file = f"board_games_{datetime.now().strftime('%Y%m%d_%H%M%S')}.xlsx"

        filename = filedialog.asksaveasfilename(
            defaultextension=".xlsx",
            filetypes=[("Excel files", "*.xlsx"), ("All files", "*.*")],
            initialdir=initial_dir,
            initialfile=initial_file,
            title="Сохранить Excel файл"
        )

        if filename:
            try:
                df = pd.DataFrame(games_data)
                df.to_excel(filename, index=False, sheet_name="Настольные игры")

                # Сохраняем путь для будущих экспортов
                self.settings["last_export_path"] = str(Path(filename).parent)
                save_settings(self.settings)

                messagebox.showinfo("Экспорт", f"Успешно экспортировано {len(games_data)} игр в файл:\n{filename}")
            except Exception as e:
                messagebox.showerror("Ошибка экспорта", f"Не удалось сохранить файл:\n{str(e)}")

    def import_from_excel(self):
        """Импорт игр из Excel файла с выбором пути"""
        initial_dir = self.settings.get("last_import_path", str(Path.home() / "Desktop"))

        filename = filedialog.askopenfilename(
            filetypes=[("Excel files", "*.xlsx *.xls"), ("All files", "*.*")],
            initialdir=initial_dir,
            title="Выберите Excel файл для импорта"
        )

        if not filename:
            return

        # Сохраняем путь для будущих импортов
        self.settings["last_import_path"] = str(Path(filename).parent)
        save_settings(self.settings)

        try:
            df = pd.read_excel(filename)

            column_mapping = {
                'name': 'name', 'название': 'name',
                'players': 'players', 'игроки': 'players',
                'age': 'age', 'возраст': 'age',
                'time_minutes': 'time_minutes', 'время': 'time_minutes', 'время партии': 'time_minutes',
                'interaction': 'interaction', 'взаимодействие': 'interaction', 'тип взаимодействия': 'interaction',
                'randomness': 'randomness', 'случайность': 'randomness',
                'quantity': 'quantity', 'количество': 'quantity', 'кол-во': 'quantity'
            }

            rename_dict = {}
            for col in df.columns:
                col_lower = col.lower().strip()
                if col_lower in column_mapping:
                    rename_dict[col] = column_mapping[col_lower]

            if rename_dict:
                df = df.rename(columns=rename_dict)

            expected_columns = ['name', 'players', 'age', 'time_minutes', 'interaction', 'randomness', 'quantity']
            missing_cols = [col for col in expected_columns if col not in df.columns]
            if missing_cols:
                messagebox.showerror("Ошибка импорта",
                                     f"Файл не содержит необходимых колонок:\n{', '.join(missing_cols)}")
                return

            df = df[expected_columns].copy()
            df['quantity'] = pd.to_numeric(df['quantity'], errors='coerce').fillna(1).astype(int)
            df['name'] = df['name'].fillna('').astype(str)
            df['players'] = df['players'].fillna('').astype(str)
            df['age'] = df['age'].fillna('').astype(str)
            df['time_minutes'] = df['time_minutes'].fillna('').astype(str)
            df['interaction'] = df['interaction'].fillna('Кооперативная').astype(str)
            df['randomness'] = df['randomness'].fillna('Низкий').astype(str)

            df = df[df['name'].str.strip() != '']

            if df.empty:
                messagebox.showwarning("Импорт", "Файл не содержит корректных данных для импорта")
                return

            if not messagebox.askyesno("Импорт", f"Найдено {len(df)} игр для импорта.\n\n"
                                                 f"Будут добавлены только новые игры (дубликаты по названию будут пропущены).\n\n"
                                                 f"Продолжить?"):
                return

            conn = sqlite3.connect(DB_FILE)
            cursor = conn.cursor()

            existing = set(row[0] for row in cursor.execute("SELECT name FROM games").fetchall())

            added = 0
            skipped = 0

            for _, row in df.iterrows():
                name = row['name'].strip()
                if name in existing:
                    skipped += 1
                    continue

                cursor.execute('''
                    INSERT INTO games (name, players, age, time_minutes, interaction, randomness, quantity)
                    VALUES (?, ?, ?, ?, ?, ?, ?)
                ''', (name, row['players'], row['age'], row['time_minutes'],
                      row['interaction'], row['randomness'], row['quantity']))
                added += 1
                existing.add(name)

            conn.commit()
            conn.close()

            if added > 0:
                self.load_games()
                messagebox.showinfo("Импорт", f"Успешно импортировано {added} игр.\nПропущено дубликатов: {skipped}")
            else:
                messagebox.showinfo("Импорт", f"Новых игр не добавлено. Все {skipped} игр уже существуют в базе.")

        except Exception as e:
            messagebox.showerror("Ошибка импорта", f"Не удалось прочитать файл:\n{str(e)}")

