    def refresh_buttons(self, event=None):
        """Обновляет позиции кнопок-смайликов для всех видимых строк"""
        # Удаляем старые кнопки
        for btn_dict in self.action_buttons.values():
            for btn in btn_dict.values():
                if isinstance(btn, (tk.Button, tk.Frame)):
                    try:
                        btn.destroy()
                    except:
                        pass
        self.action_buttons.clear()

        # Для каждого элемента в tree создаём кнопки, если строка видима
        for item in self.tree.get_children():
            bbox = self.tree.bbox(item)
            if bbox:
                col_bbox = self.tree.bbox(item, column="#8")
                if col_bbox:
                    x, y, width, height = col_bbox
                    btn_frame = tk.Frame(self.tree, bg=CARD_BG)
                    btn_frame.place(x=x + 5, y=y + 2, width=width - 10, height=height - 4)

                    edit_btn = tk.Button(btn_frame, text="✏️", font=("Segoe UI", 10),
                                         bg=CARD_BG, fg=FG_LIGHT, bd=1, relief=tk.SOLID,
                                         highlightbackground=BUTTON_BORDER, highlightcolor=BUTTON_BORDER,
                                         highlightthickness=1, cursor="hand2",
                                         command=lambda i=item: self.edit_game(i))
                    edit_btn.pack(side=tk.LEFT, padx=2, expand=True, fill=tk.BOTH)

                    del_btn = tk.Button(btn_frame, text="🗑️", font=("Segoe UI", 10),
                                        bg=CARD_BG, fg=FG_LIGHT, bd=1, relief=tk.SOLID,
                                        highlightbackground=BUTTON_BORDER, highlightcolor=BUTTON_BORDER,
                                        highlightthickness=1, cursor="hand2",
                                        command=lambda i=item: self.delete_game(i))
                    del_btn.pack(side=tk.LEFT, padx=2, expand=True, fill=tk.BOTH)

                    self.action_buttons[item] = {"frame": btn_frame, "edit": edit_btn, "delete": del_btn}

    def validate_name(self, name):
        if not name or name.strip() == "" or name.strip() == "Название игры...":
            return False, "Название игры не может быть пустым"
        return True, ""

    def validate_players(self, players):
        # Разрешаем только цифры и дефис, запрещаем минус в начале
        if not re.match(r'^\d+[\d\-]*$', players.strip()):
            return False, "Поле 'Игроки' должно быть числом или диапазоном (напр. 2-4)"
        return True, ""

    def validate_age(self, age):
        # Только цифры и возможный плюс в конце
        if not re.match(r'^\d+\+?$', age.strip()):
            return False, "Поле 'Возраст' должно быть числом (напр. 12+)"
        return True, ""

    def validate_time(self, time_str):
        if not re.match(r'^\d+[\d\-]*$', time_str.strip()):
            return False, "Поле 'Время' должно быть числом или диапазоном (напр. 30-60)"
        return True, ""

    def validate_quantity(self, quantity, is_available):
        """Проверка количества"""
        if quantity < 0:
            return False, "Количество не может быть отрицательным"
        if quantity > 999:
            return False, "Количество не может превышать 999"
        if is_available:
            if quantity < 1:
                return False, "Если игра в наличии, количество должно быть не менее 1"
        else:
            if quantity != 0:
                return False, "Если игра не в наличии, количество должно быть 0"
        return True, ""

    def show_field_error(self, field_name, error_message):
        """Показывает ошибку для конкретного поля"""
        messagebox.showerror(f"Ошибка в поле '{field_name}'", error_message)

    def export_to_excel(self):
        """Экспорт отфильтрованных игр в Excel файл с выбором пути"""
        # Собираем данные из отображаемых строк
        games_data = []
        for item in self.tree.get_children():
            values = self.tree.item(item, "values")
            if values and len(values) >= 7:
                games_data.append({
                    'Название': values[0],
                    'Игроки': values[1],
                    'Возраст': values[2],
                    'Время (мин)': values[3],
                    'Взаимодействие': values[4],
                    'Случайность': values[5],
                    'Количество': values[6]
                })

        if not games_data:
            messagebox.showwarning("Экспорт", "Нет данных для экспорта")
            return

        # Предлагаем выбрать путь для сохранения
        initial_dir = self.settings.get("last_export_path", str(Path.home() / "Desktop"))
        initial_file = f"board_games_{datetime.now().strftime('%Y%m%d_%H%M%S')}.xlsx"

        filename = filedialog.asksaveasfilename(
            defaultextension=".xlsx",
            filetypes=[("Excel files", "*.xlsx"), ("All files", "*.*")],
            initialdir=initial_dir,
            initialfile=initial_file,
            title="Сохранить Excel файл"
        )

        if filename:
            try:
                df = pd.DataFrame(games_data)
                df.to_excel(filename, index=False, sheet_name="Настольные игры")

                # Сохраняем путь для будущих экспортов
                self.settings["last_export_path"] = str(Path(filename).parent)
                save_settings(self.settings)

                messagebox.showinfo("Экспорт", f"Успешно экспортировано {len(games_data)} игр в файл:\n{filename}")
            except Exception as e:
                messagebox.showerror("Ошибка экспорта", f"Не удалось сохранить файл:\n{str(e)}")

    def import_from_excel(self):
        filename = filedialog.askopenfilename(filetypes=[("Excel files", "*.xlsx")])
        if not filename: return

        try:
            # Читаем файл
            df = pd.read_excel(filename)

            # Отладочное сообщение (поможет понять, сколько колонок видит программа)
            print(f"Колонок найдено: {len(df.columns)}")
            print(f"Названия колонок: {list(df.columns)}")

            conn = sqlite3.connect(DB_FILE)
            cursor = conn.cursor()

            for index, row in df.iterrows():
                # Превращаем строку в список, чтобы безопасно достать данные
                data = row.tolist()

                # Проверка: есть ли у нас хотя бы 7 элементов в строке
                if len(data) < 7:
                    raise ValueError(f"В строке {index + 2} недостаточно данных (всего {len(data)})")

                cursor.execute('''INSERT INTO games 
                                 (name, players, age, time_minutes, interaction, randomness, quantity) 
                                 VALUES (?, ?, ?, ?, ?, ?, ?)''',
                               (str(data[0]), str(data[1]), str(data[2]), str(data[3]),
                                str(data[4]), str(data[5]), int(data[6])))

            conn.commit()
            conn.close()
            self.load_games()
            messagebox.showinfo("Успех", "Игры успешно импортированы!")

        except Exception as e:
            # Теперь сообщение об ошибке покажет реальную причину
            messagebox.showerror("Ошибка импорта", f"Детали ошибки: {str(e)}")
